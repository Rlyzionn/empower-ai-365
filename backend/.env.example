# ============================================================
#  VOICEDESK BACKEND — Environment Variables
#  Copy this file to .env and fill in your values
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000     # Your dashboard URL (for CORS)

# ── Supabase ────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbG...               # Used for auth verification
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...       # Full admin access — never expose publicly

# ── Retell AI (Managed Layer) ────────────────────────────────
# Get from: https://app.retellai.com → Settings → API Key
RETELL_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxx
RETELL_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxx   # Set when creating webhook in Retell dashboard

# ── n8n Automation ──────────────────────────────────────────
# Your n8n instance webhook URL — triggers CRM sync, Slack alerts, etc.
# Self-hosted: https://your-n8n.domain.com/webhook/voicedesk
# Cloud:       https://your-account.app.n8n.cloud/webhook/voicedesk
N8N_WEBHOOK_URL=https://your-n8n.domain.com/webhook/voicedesk
N8N_SECRET=your-n8n-webhook-secret         # Shared secret to verify n8n calls

# ── Slack (Platform-level alerts — YOUR Slack, not client's) ─
# Get from: https://api.slack.com/apps → Your App → OAuth Tokens
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL_LEADS=#voicedesk-leads       # Where new leads get posted
SLACK_CHANNEL_ALERTS=#voicedesk-alerts     # Where escalations + errors go

# ── Encryption ──────────────────────────────────────────────
# Used to encrypt API keys stored in the database
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# ── Optional: Direct CRM Keys ───────────────────────────────
# Only needed if NOT using n8n — if using n8n, configure these inside n8n instead
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GHL_API_KEY=your-go-high-level-api-key

# ── Optional: Telnyx (phone number management) ───────────────
TELNYX_API_KEY=KEY...                      # For programmatic number provisioning
